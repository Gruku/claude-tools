# Local workspace — scratch files, source templates, build artifacts
.workspace/

# Dependencies
node_modules/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Plugin eval/test workspaces (generated by skill-creator)
*-workspace/

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# Stale/empty directories
codex-dispatch/

# Superpowers docs (local-only specs and plans)
docs/superpowers/

# Brainstorm artifacts (local-only concept HTMLs from brainstorming skill)
.superpowers/

# Logs
*.log

# Git worktrees
.worktrees/

# Taskmaster v3 runtime — snapshots and auto-mode state
# (covers both .taskmaster/ and .claude/ "hidden mode" project layouts)
.taskmaster/snapshots/
.taskmaster/auto/
.claude/snapshots/
.claude/auto/

# Taskmaster v3 session-ephemeral entities — kept local, not tracked
# Handovers / issues / lessons capture personal session context that
# shouldn't live in the public repo. Local-only by user preference.
.taskmaster/handovers/
.taskmaster/issues/
.taskmaster/lessons/
.claude/handovers/
.claude/issues/
.claude/lessons/

# Taskmaster v3 backlog + tasks + progress — local-only by user preference.
# Public repo ships taskmaster as a tool, not as a record of one user's work.
# Anyone using this repo runs their own taskmaster against an empty backlog.
.taskmaster/backlog.yaml
.taskmaster/tasks/
.taskmaster/PROGRESS.md
.claude/backlog.yaml
.claude/tasks/
.claude/PROGRESS.md
