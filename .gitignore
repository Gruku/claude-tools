# Local workspace — scratch files, source templates, build artifacts
.workspace/

# Dependencies
node_modules/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Plugin eval/test workspaces (generated by skill-creator)
*-workspace/

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# Stale/empty directories
codex-dispatch/

# Superpowers docs (local-only specs and plans)
docs/superpowers/

# Reflection / postmortem reports (local-only)
docs/reflect/

# Taskmaster local-only planning docs (specs + generalization plans)
plugins/taskmaster/docs/specs/
plugins/taskmaster/docs/generalization-plan.md

# Brainstorm artifacts (local-only concept HTMLs from brainstorming skill)
.superpowers/

# Logs
*.log

# Git worktrees
.worktrees/

# Taskmaster v3 runtime — entire .taskmaster/ directory is local-only.
# Public repo ships taskmaster as a tool, not as a record of one user's work.
# Anyone using this repo runs their own taskmaster against an empty backlog.
.taskmaster/

# Legacy `.claude/` taskmaster layout — same intent, kept granular because
# `.claude/` also holds tracked harness config (settings.json, hooks, skills).
.claude/snapshots/
.claude/auto/
.claude/handovers/
.claude/issues/
.claude/lessons/
.claude/backlog.yaml
.claude/tasks/
.claude/PROGRESS.md
