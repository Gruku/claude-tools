{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-version-bump.sh\"",
            "timeout": 10,
            "statusMessage": "Checking plugin versions..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": false,
    "mcp-server-dev@claude-plugins-official": true
  }
}
