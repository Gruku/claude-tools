{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_SCRIPT=guard_bash.py . \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_SCRIPT=guard_edits.py . \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_SCRIPT=ask_question_approval.py . \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_SCRIPT=consume_approval.py . \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_SCRIPT=guard_approve.py . \"${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
